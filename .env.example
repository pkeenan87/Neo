# Neo Security Agent — Environment Variables
# Copy to .env and fill in your values.

# Required — Claude API key
ANTHROPIC_API_KEY=

# Claude model IDs (override when Anthropic releases new versions)
# Update these app settings instead of redeploying code.
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_OPUS_MODEL=claude-opus-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# Organization name — appears in the system prompt (e.g., "for Acme Corp's security team").
# Defaults to "Goodwin Procter LLP" if not set. Set to empty to use "your organization".
ORG_NAME=Goodwin Procter LLP

# Organizational context — injected into the system prompt to help Neo investigate.
# Add domain names, SAM account formats, VPN ranges, critical assets, etc.
# Supports \n for newlines. Also editable by admins in Settings > Organization.
# ORG_CONTEXT=Primary domains: acme.com, acmecorp.onmicrosoft.com\nSAM format: first.last

# Per-turn output-token budgets (max_tokens)
# MAX_TOKENS_DEFAULT is the cap for plain chat turns; MAX_TOKENS_SKILL is
# the larger cap applied when a user invokes a skill via slash command
# (skills produce longer structured output). MAX_TOKENS_CEILING_OVERRIDE
# optionally hard-caps both regardless of the model's published ceiling —
# useful for cost control. Each value is clamped to the active model's
# published output-token ceiling at runtime; a one-time warning fires at
# boot if the configured value exceeded that ceiling.
MAX_TOKENS_DEFAULT=4096
MAX_TOKENS_SKILL=24576
# MAX_TOKENS_CEILING_OVERRIDE=

# Usage limits (per-user token budgets)
# Defaults approximate $10 (2h) and $100 (weekly) of Opus usage.
# Adjust without rebuilding — restart the server to pick up changes.
USAGE_LIMIT_2H_INPUT_TOKENS=670000
USAGE_LIMIT_WEEKLY_INPUT_TOKENS=6700000
# Set to "false" to disable all token budget enforcement (default: true).
# Usage is still tracked for dashboards when disabled. Useful for demos,
# onboarding, and incident response.
ENABLE_USAGE_LIMITS=true

# Mock mode (default: true)
# Set to false and add Azure credentials below for live API calls
MOCK_MODE=true

# Dev auth bypass (set to true in development to skip SSO)
DEV_AUTH_BYPASS=false
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# Auth.js secret — generate with: openssl rand -hex 32
# IMPORTANT: Must be identical across all App Service instances in scale-out deployments.
# Mismatched secrets cause PKCE cookie decryption failures.
AUTH_SECRET=

# Trust host header (required for Azure App Service / reverse proxy deployments)
AUTH_TRUST_HOST=true

# Base URL for Auth.js callback redirects (must match Entra ID redirect URI)
# IMPORTANT: Must be your actual HTTPS domain in production (e.g., https://neo.yourdomain.com).
# Using http:// in production causes PKCE cookie failures on Azure App Service.
AUTH_URL=http://localhost:3000

# Microsoft Entra ID (optional — for browser-based web auth)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# Azure credentials (required when MOCK_MODE=false)
# The app registration needs these API permissions:
#   - Microsoft Graph: Mail.Read, Mail.Send (for message search and phishing reports)
#   - Microsoft Threat Protection: Machine.Read.All (for Defender tools)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# Phishing report intake mailbox — messages reported as phishing are forwarded here.
# Also configurable via Settings > Integrations or Key Vault secret PHISHING_REPORT_EMAIL.
# PHISHING_REPORT_EMAIL=security-phishing@yourdomain.com

# Sentinel workspace (required when MOCK_MODE=false)
SENTINEL_WORKSPACE_ID=
SENTINEL_WORKSPACE_NAME=
SENTINEL_RESOURCE_GROUP=

# Microsoft Teams Bot (optional — for Teams channel integration)
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
# Role assigned to all Teams bot users. Valid values: "admin" | "reader" (default: reader)
# "admin" enables destructive tools (password reset, machine isolation). Set explicitly if needed.
TEAMS_BOT_ROLE=reader

# Logging (optional — Event Hub for structured audit logs)
# Omit to use console-only logging.
EVENT_HUB_CONNECTION_STRING=
EVENT_HUB_NAME=neo-logs
# Optional — separate Event Hub for analytics events (tool_execution, token_usage, etc.)
# If omitted, all events go to the primary topic above.
EVENT_HUB_ANALYTICS_CONNECTION_STRING=
EVENT_HUB_ANALYTICS_NAME=neo-analytics
LOG_LEVEL=

# Cosmos DB (chat persistence)
# Omit to use in-memory session store (conversations lost on restart).
# Uses Managed Identity auth — no connection string needed.
COSMOS_ENDPOINT=

# ───────────────────────────────────────────────────────────
# Conversation storage v2 (split-document schema + blob offload)
# See _plans/conversation-storage-split-blob-offload.md.
#
# Rollout sequence (DO NOT skip steps):
#   1. Deploy with NEO_CONVERSATION_STORE_MODE=v1 (current default) —
#      no behavior change, v2 code paths idle.
#   2. Flip to NEO_CONVERSATION_STORE_MODE=dual-write. Every new
#      conversation writes to both v1 and v2; reads still come from
#      v1. Watch the `conversation_dual_write_divergence` log event
#      for at least 24h — any sustained drift indicates a bug to
#      resolve BEFORE proceeding.
#   3. Run the migration:
#        cd web && npm run migrate:conversations -- --dry-run
#        (review summary, then drop --dry-run for the real run)
#      Reverse is available via `--direction v2-to-v1` with a 2 MB
#      pre-flight check that rejects oversized rebuilds.
#   4. Flip to NEO_CONVERSATION_STORE_MODE=dual-read. Reads prefer v2,
#      fall back to v1 for not-yet-migrated ids. Dual-write continues.
#   5. After a soak period with no divergence alerts, flip to
#      NEO_CONVERSATION_STORE_MODE=v2 and stop writing to v1.
#
# Valid values: v1 | dual-write | dual-read | v2
NEO_CONVERSATION_STORE_MODE=v1

# Name of the v2 Cosmos container. Must be partitioned on
# /conversationId. Created empty alongside the legacy `conversations`
# container; the dispatch layer only touches it when mode !== v1.
NEO_CONVERSATIONS_V2_CONTAINER=neo-conversations-v2

# Azure Blob Storage container that holds offloaded tool-result
# payloads. Required once mode !== v1 AND any conversation carries a
# tool result larger than NEO_BLOB_OFFLOAD_THRESHOLD_BYTES. Must have
# a lifecycle policy on the `staging/` prefix (reap blobs not
# promoted within 7 days) for the partial-failure safety net.
NEO_TOOL_RESULT_BLOB_CONTAINER=neo-tool-results

# Byte threshold above which a tool result is offloaded to blob
# storage instead of persisted inline in the turn doc. Default 256 KB
# balances RU cost (Cosmos charges per KB of doc) against the
# per-lookup latency of resolving a blob on re-read. Lower for more
# aggressive offload; raise if your payloads are consistently small.
NEO_BLOB_OFFLOAD_THRESHOLD_BYTES=262144

# Maximum bytes resolveBlobRef is willing to stream back when the
# agent calls `get_full_tool_result`. Upper guard against a runaway
# blob reference pulling multi-GB content into the process. Default
# 20 MB comfortably covers realistic tool outputs.
NEO_BLOB_RESOLVE_MAX_BYTES=20971520

# Default retention class for new conversations. One of:
#   short-30d, standard-7y, legal-hold
# `legal-hold` suppresses TTL on Cosmos docs and skips automated
# purge — surfaces any lifecycle rule that would delete a
# retention-tagged row. See lib/retention.ts.
NEO_RETENTION_CLASS_DEFAULT=standard-7y

# CLI Downloads — Azure Blob Storage for hosting installer files.
# Uses Managed Identity auth (same as Cosmos DB) — no connection string needed.
CLI_STORAGE_ACCOUNT=
CLI_STORAGE_CONTAINER=cli-releases
# Chat file uploads — container for user-attached images and PDFs
UPLOAD_STORAGE_CONTAINER=chat-attachments

# Azure Key Vault (optional — for managing tool secrets via /integrations admin UI)
# Uses Managed Identity auth — no connection string needed.
# Omit to use environment variables for tool secrets (existing behavior).
# WARNING: When DEV_AUTH_BYPASS=true, all users get admin access to /integrations.
# Point this at a personal dev vault, not a shared staging vault.
KEY_VAULT_URL=
# Key Vault key name for API key encryption (used with KEY_VAULT_URL)
KEY_VAULT_KEY_NAME=neo-api-key-encryption
# Comma-separated list of ownerIds that can view and revoke all API keys.
# Regular admins can only manage their own keys.
SUPER_ADMIN_IDS=

# Lansweeper asset management (optional — only needed when MOCK_MODE=false)
LANSWEEPER_API_TOKEN=
LANSWEEPER_SITE_ID=

# Abnormal Security (optional — only needed when MOCK_MODE=false)
ABNORMAL_API_TOKEN=

# Prompt injection guard mode for user input scanning.
# "monitor" logs detections but allows all requests through (default, recommended until
# false-positive rate is calibrated against real traffic).
# "block" rejects requests with 2+ pattern matches with a generic 400 error.
INJECTION_GUARD_MODE=monitor
