# Neo Security Agent — Environment Variables
# Copy to .env and fill in your values.

# Required — Claude API key
ANTHROPIC_API_KEY=

# Mock mode (default: true)
# Set to false and add Azure credentials below for live API calls
MOCK_MODE=true

# Auth.js secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# Microsoft Entra ID (optional — for browser-based web auth)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# Azure credentials (required when MOCK_MODE=false)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# Sentinel workspace (required when MOCK_MODE=false)
SENTINEL_WORKSPACE_ID=
SENTINEL_WORKSPACE_NAME=
SENTINEL_RESOURCE_GROUP=

# Microsoft Teams Bot (optional — for Teams channel integration)
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
# Service principal object ID for the bot app registration (for RBAC role lookups)
# Find via: az ad sp show --id $MICROSOFT_APP_ID --query id -o tsv
MICROSOFT_APP_SP_OBJECT_ID=

# Logging (optional — Event Hub for structured audit logs)
# Omit to use console-only logging.
EVENT_HUB_CONNECTION_STRING=
EVENT_HUB_NAME=neo-logs
LOG_LEVEL=

# Prompt injection guard mode for user input scanning.
# "monitor" logs detections but allows all requests through (default, recommended until
# false-positive rate is calibrated against real traffic).
# "block" rejects requests with 2+ pattern matches with a generic 400 error.
INJECTION_GUARD_MODE=monitor
