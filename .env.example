# Neo Security Agent — Environment Variables
# Copy to .env and fill in your values.

# Required — Claude API key
ANTHROPIC_API_KEY=

# Mock mode (default: true)
# Set to false and add Azure credentials below for live API calls
MOCK_MODE=true

# Dev auth bypass (set to true in development to skip SSO)
DEV_AUTH_BYPASS=false
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# Auth.js secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# Trust host header (required for Azure App Service / reverse proxy deployments)
AUTH_TRUST_HOST=true

# Base URL for Auth.js callback redirects (must match Entra ID redirect URI)
# e.g. http://localhost:3000 for local dev, https://yourdomain.com for production
AUTH_URL=http://localhost:3000

# Microsoft Entra ID (optional — for browser-based web auth)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# Azure credentials (required when MOCK_MODE=false)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# Sentinel workspace (required when MOCK_MODE=false)
SENTINEL_WORKSPACE_ID=
SENTINEL_WORKSPACE_NAME=
SENTINEL_RESOURCE_GROUP=

# Microsoft Teams Bot (optional — for Teams channel integration)
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
# Role assigned to all Teams bot users. Valid values: "admin" | "reader" (default: reader)
# "admin" enables destructive tools (password reset, machine isolation). Set explicitly if needed.
TEAMS_BOT_ROLE=reader

# Logging (optional — Event Hub for structured audit logs)
# Omit to use console-only logging.
EVENT_HUB_CONNECTION_STRING=
EVENT_HUB_NAME=neo-logs
LOG_LEVEL=

# Cosmos DB (chat persistence)
# Omit to use in-memory session store (conversations lost on restart).
# Uses Managed Identity auth — no connection string needed.
COSMOS_ENDPOINT=

# CLI Downloads — Azure Blob Storage for hosting installer files.
# Uses Managed Identity auth (same as Cosmos DB) — no connection string needed.
CLI_STORAGE_ACCOUNT=
CLI_STORAGE_CONTAINER=cli-releases

# Azure Key Vault (optional — for managing tool secrets via /integrations admin UI)
# Uses Managed Identity auth — no connection string needed.
# Omit to use environment variables for tool secrets (existing behavior).
# WARNING: When DEV_AUTH_BYPASS=true, all users get admin access to /integrations.
# Point this at a personal dev vault, not a shared staging vault.
KEY_VAULT_URL=

# Prompt injection guard mode for user input scanning.
# "monitor" logs detections but allows all requests through (default, recommended until
# false-positive rate is calibrated against real traffic).
# "block" rejects requests with 2+ pattern matches with a generic 400 error.
INJECTION_GUARD_MODE=monitor
