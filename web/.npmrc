# Pin direct dependencies to exact versions on `npm install <pkg>`
save-exact=true

# Refuse to install package versions younger than 72 hours (4320 minutes).
# Gives the community time to detect compromised releases (e.g., the
# axios 1.14.1 / 0.30.4 supply chain attack on 2026-03-31, which was
# unpublished within ~3 hours but only after some users had installed it).
# Config key is kebab-case in npm CLI: `min-release-age` (not camelCase).
min-release-age=4320

# Quality of life — suppress funding messages on install.
fund=false
